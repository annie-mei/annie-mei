# Discord Bot Token from Discord Developer Portal
DISCORD_TOKEN=

# Sentry DSN for error tracking
SENTRY_DSN=

# Environment name (development, staging, production)
ENV=development

# PostgreSQL connection string
DATABASE_URL=postgres://user:password@localhost/annie_mei

# Redis connection URL (local: redis://localhost:6379, Upstash: rediss://...)
REDIS_URL=redis://localhost:6379

# Spotify API credentials (from Spotify Developer Dashboard)
RSPOTIFY_CLIENT_ID=
RSPOTIFY_CLIENT_SECRET=

# Secret salt for hashing user IDs in logs (generate a random string)
USERID_HASH_SALT=

# Gemini / OpenAI-compatible LLM API key (from Google AI Studio)
GEMINI_API_KEY=

# AI model name (optional, default: gemini-2.0-flash)
# AI_MODEL=gemini-2.0-flash

# AI base URL (optional, default: Google Gemini OpenAI-compatible endpoint)
# AI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai

# Tracing/logging level (optional)
RUST_LOG=info
